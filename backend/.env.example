# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# PostgreSQL Database Configuration (WMS)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pixel_logistics_wms
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_POOL_MAX=20
DB_POOL_MIN=5

# MongoDB Configuration (TMS)
MONGO_URI=mongodb://localhost:27017/pixel_logistics_tms
MONGO_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_key
JWT_REFRESH_EXPIRE=30d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@pixellogistics.com

# WebSocket Configuration
WS_PORT=5001
WS_PATH=/socket.io

# Session Configuration
SESSION_SECRET=your_session_secret_key
SESSION_EXPIRE=86400000

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# API Documentation
SWAGGER_ENABLED=true
SWAGGER_PATH=/api-docs

# Security
BCRYPT_ROUNDS=10
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=1800000

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
