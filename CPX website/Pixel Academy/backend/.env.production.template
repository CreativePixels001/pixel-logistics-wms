# Environment Variables - PRODUCTION
# Copy this file to .env and fill in the values

# ===========================================
# SERVER CONFIGURATION
# ===========================================
NODE_ENV=production
PORT=8080

# ===========================================
# DATABASE CONFIGURATION (AWS RDS)
# ===========================================
# After creating RDS instance, AWS will provide these:
DB_HOST=pixel-academy-db.xxxxxxxxx.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=pixel_academy_prod
DB_USER=postgres
DB_PASSWORD=YOUR_STRONG_DB_PASSWORD_HERE

# ===========================================
# JWT CONFIGURATION
# ===========================================
# Generate new secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_NEW_SECRET_HERE_MIN_64_CHARS
JWT_EXPIRES_IN=7d

# ===========================================
# GOOGLE OAUTH CONFIGURATION
# ===========================================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-production-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-production-secret

# ===========================================
# FILE UPLOAD CONFIGURATION
# ===========================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes

# ===========================================
# AWS S3 CONFIGURATION (for file uploads)
# ===========================================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIA_YOUR_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_BUCKET=pixel-academy-uploads

# ===========================================
# CORS CONFIGURATION
# ===========================================
# Your production frontend URL
FRONTEND_URL=https://your-domain.com
# Or if using FTP server IP:
# FRONTEND_URL=http://68.178.157.215

# ===========================================
# ADMIN CONFIGURATION
# ===========================================
ADMIN_EMAILS=admin@creativepixels.in,ashish@creativepixels.in

# ===========================================
# OPTIONAL: EMAIL CONFIGURATION (for notifications)
# ===========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@creativepixels.in
# SMTP_PASSWORD=your_email_password
# EMAIL_FROM=Pixel Academy <noreply@creativepixels.in>

# ===========================================
# SECURITY HEADERS
# ===========================================
HELMET_ENABLED=true
RATE_LIMIT_WINDOW=15  # minutes
RATE_LIMIT_MAX=100    # requests per window
