# Environment variables for Pixel Write
# Copy this file to .env and fill in your values

# OpenAI API Configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# Alternative: Anthropic Claude
# ANTHROPIC_API_KEY=your-claude-key-here

# News API Keys (Optional - for enhanced trend monitoring)
# NEWS_API_KEY=your-newsapi-key-here

# Pixel Fact Integration
PIXELFACT_PATH=../frontend/PixelFact
AUTO_PUBLISH=false

# Generation Settings
ARTICLES_PER_DAY=2
SCHEDULE_TIME_1=09:00
SCHEDULE_TIME_2=18:00

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=true

# Optional: Database connection (future feature)
# DATABASE_URL=mongodb://localhost:27017/pixelwrite
